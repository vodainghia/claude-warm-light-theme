  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8a8272",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#8b5a2b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "punctuation"
      ],
      "settings": {
        "foreground": "#7a6a50",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#5a7a3a"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#6a8a5a"
      }
    },
    {
      "scope": [
        "punctuation.definition.template-expression",
        "string.template punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#8b5a2b"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#9a6030"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#9a5050",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#6a5acd"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#2e7d7a"
      }
    },
    {
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#2e7d7a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type.parameter"
      ],
      "settings": {
        "foreground": "#8a5a8a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#3d3929"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#5a5344",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#5a6a8a"
      }
    },
    {
      "scope": [
        "variable.other.enummember",
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#9a6030"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#7a5a9a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.namespace",
        "entity.name.module"
      ],
      "settings": {
        "foreground": "#6b6352"
      }
    },
    {
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#8b5a2b",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#8b5a2b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9a6030",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#5a6a8a"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#9a6030"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#2e7d7a"
      }
    },
    {
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#5a6a8a"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#8b5a2b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#3d3929",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#3d3929",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#6a5acd"
      }
    },
    {
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#5a7a9a"
      }
    },
    {
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#5a6a8a"
      }
    },
    {
      "scope": [
        "source.shell variable"
      ],
      "settings": {
        "foreground": "#5a6a8a"
      }
    },
    {
      "scope": [
        "variable.defaultLibrary"
      ],
      "settings": {
        "foreground": "#6b6352"
      }
    },
    {
      "scope": [
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#2e7d7a"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#6b6352",
    "type": "#2e7d7a",
    "type.declaration": "#2e7d7a",
    "interface": {
      "foreground": "#2e7d7a",
      "fontStyle": "italic"
    },
    "class": "#2e7d7a",
    "enum": "#9a6030",
    "enumMember": "#9a6030",
    "function": "#6a5acd",
    "function.declaration": "#6a5acd",
    "method": "#6a5acd",
    "method.declaration": "#6a5acd",
    "parameter": {
      "foreground": "#5a5344",
      "fontStyle": "italic"
    },
    "variable": "#3d3929",
    "variable.readonly": "#3d3929",
    "variable.declaration": "#3d3929",
    "property": "#5a6a8a",
    "property.declaration": "#5a6a8a",
    "property.readonly": "#5a6a8a",
    "decorator": {
      "foreground": "#7a5a9a",
      "fontStyle": "italic"
    },
    "typeParameter": "#8a5a8a"
  }
}
